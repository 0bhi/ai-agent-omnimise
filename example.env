# =========================
# Backend — Turso only
# =========================
# From Turso dashboard: database URL + token (no local sqlite file).

DATABASE_URL=libsql://your-db-name-your-org.aws-region.turso.io
TURSO_AUTH_TOKEN=

ADMIN_TOKEN=dev-admin-change-me
CORS_DEV=true

SCHEDULED_SCRAPE_ENABLED=false
SCRAPE_INTERVAL_MINUTES=360

BUDDY4STUDY_LIST_URL=https://www.buddy4study.com/scholarships
HTTP_USER_AGENT=OmnimiseScholarshipBot/0.1 (+https://example.local)
SCRAPE_REQUEST_DELAY_SECONDS=0.25
MAX_SCRAPE_DETAIL_PAGES=12

LLM_API_BASE=https://api.groq.com/openai/v1
LLM_API_KEY=
LLM_CHAT_MODEL=llama-3.3-70b-versatile
MATCH_RETRIEVAL_K=60
MATCH_LLM_TOP_K=20

GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=text-embedding-004
LLM_EMBEDDING_MODEL=text-embedding-3-small


# =========================
# Frontend (frontend/.env)
# =========================
VITE_API_BASE_URL=http://127.0.0.1:8000
