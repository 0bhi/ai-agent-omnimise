# =========================
# Backend (app/config.py)
# =========================

# Database / storage
DATABASE_URL=sqlite:///./data/app.db
DATA_DIR=data
RESUME_DIR=data/resumes

# Security / API behavior
ADMIN_TOKEN=dev-admin-change-me
CORS_DEV=true

# Scheduled scrape
SCHEDULED_SCRAPE_ENABLED=false
SCRAPE_INTERVAL_MINUTES=360

# Scraper settings
BUDDY4STUDY_LIST_URL=https://www.buddy4study.com/scholarships
HTTP_USER_AGENT=OmnimiseScholarshipBot/0.1 (+https://example.local)
SCRAPE_REQUEST_DELAY_SECONDS=0.25
MAX_SCRAPE_DETAIL_PAGES=12

# Hybrid retrieval + LLM rerank
# Chat: Groq (OpenAI-compatible). Leave LLM_API_KEY empty to skip LLM rerank (fallback scores still work).
LLM_API_BASE=https://api.groq.com/openai/v1
LLM_API_KEY=
LLM_CHAT_MODEL=llama-3.3-70b-versatile
MATCH_RETRIEVAL_K=60
MATCH_LLM_TOP_K=20

# Embeddings: Google Gemini (recommended with Groq chat). If unset, falls back to OpenAI-style /embeddings on LLM_API_BASE when LLM_API_KEY is set.
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=text-embedding-004
# Only used when GEMINI_API_KEY is not set (OpenAI-compatible embeddings endpoint).
LLM_EMBEDDING_MODEL=text-embedding-3-small


# =========================
# Frontend (frontend/src/App.tsx)
# =========================
# Put this in frontend/.env for Vite in local dev.
VITE_API_BASE_URL=http://127.0.0.1:8000
